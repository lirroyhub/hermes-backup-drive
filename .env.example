# Hermes Agent backup stack — environment TEMPLATE
# -------------------------------------------------
# Copy this file to `.env` and fill in real values.
# The real `.env` is git-ignored and must NEVER be committed.
#
#   cp .env.example .env
#   then edit the values below

# --- Path to your Hermes data on the HOST -----------------------------------
# This is the directory that gets backed up — your live Hermes install's home.
# Use an ABSOLUTE path. A literal "~" can be unreliable as a compose volume
# source. Typical locations:
#   macOS / Linux single user:  /Users/you/.hermes   or  /home/you/.hermes
#   root install:               /root/.hermes
HERMES_DATA_PATH=/Users/you/.hermes

# --- Backup behavior --------------------------------------------------------
# full  = complete snapshot (config, skills, sessions, memory)
# quick = state-only fast snapshot
BACKUP_MODE=full

# Days of dated backup folders to keep before pruning (local + Drive). 0 = keep all.
RETENTION_DAYS=30

# Timezone for the backup schedule (and the container clock).
TZ=America/Montevideo

# --- Encryption (recommended) -----------------------------------------------
# The Hermes archive contains your .env with API keys and bot tokens. Encrypt
# it before it leaves the machine.
ENCRYPT=false
# Required when ENCRYPT=true. Use a long random passphrase and store it SAFELY
# OUTSIDE this repo (a password manager). Losing it means losing the backups.
#   openssl rand -hex 32
GPG_PASSPHRASE=

# --- Google Drive (rclone) --------------------------------------------------
# Name of the rclone remote you configure on the host (see README section 4).
RCLONE_REMOTE=gdrive
# Folder path inside the remote (Google Drive) to upload into. Dated subfolders
# (YYYY-MM-DD) are created underneath automatically.
RCLONE_DEST_PATH=hermes-backups
