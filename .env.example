# ──────────────────────────────────────────────────────────────────────────
# Hermes Backup → Google Drive  ·  configuration
# Copy this file to `.env` and edit. `.env` is gitignored.
# ──────────────────────────────────────────────────────────────────────────

# Timezone for the schedule (e.g. America/Montevideo, Europe/Madrid, UTC).
TZ=UTC

# When to run, standard 5-field cron syntax: minute hour day month weekday.
# Default: every day at 03:00. The bundled scheduler handles a simple daily
# time directly; see README for full-cron options.
BACKUP_CRON=0 3 * * *

# ── Paths on the HOST ──────────────────────────────────────────────────────
# Your Hermes data directory. This is what gets backed up. Usually ~/.hermes.
HERMES_DATA_PATH=~/.hermes

# Path to an rclone.conf that defines your Google Drive remote.
# See README "Setting up the Google Drive remote".
RCLONE_CONFIG_PATH=./rclone.conf

# ── Google Drive destination ───────────────────────────────────────────────
# Name of the rclone remote (must match what's in rclone.conf).
RCLONE_REMOTE=gdrive
# Folder (path) inside that remote to upload into. Created if missing.
RCLONE_REMOTE_PATH=hermes-backups

# ── Backup behavior ────────────────────────────────────────────────────────
# full  = complete snapshot (config, skills, sessions, memory)
# quick = state-only fast snapshot
BACKUP_MODE=full

# Delete backups older than this many days, locally AND on Drive. 0 = keep all.
RETENTION_DAYS=14

# Encrypt the archive with gpg (AES-256) before upload. Strongly recommended,
# because the archive contains your .env with API keys and bot tokens.
ENCRYPT=false
# Required when ENCRYPT=true. Use a long random passphrase and store it safely
# OUTSIDE this repo (a password manager). Losing it means losing the backups.
GPG_PASSPHRASE=

# Run a backup immediately when the container starts (handy for first test).
RUN_ON_START=false
